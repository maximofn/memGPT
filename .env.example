# Primary LLM (modern, used by the agent loop)
PRIMARY_LLM_MODEL=claude-sonnet-4-6

# Summarizer LLM (cheap, used to regenerate the recursive summary)
SUMMARIZER_LLM_MODEL=claude-haiku-4-5

# Provider API keys (set the ones matching the models above)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# PostgreSQL (LangGraph checkpointer + store)
POSTGRES_DSN=postgresql://memgpt:memgpt@localhost:5432/memgpt

# Neo4j (Graphiti backend)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=memgptmemgpt
